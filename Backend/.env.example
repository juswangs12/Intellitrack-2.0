# IntelliTrack Backend Environment Variables Template
# Copy this file to .env and fill in your actual production values

# ===========================================
# DATABASE CONFIGURATION (Supabase Session Pooler)
# ===========================================
# Use the connection string from Supabase (Settings -> Database -> Connection string -> JDBC)
# For Session Pooler, use port 5432. For Transaction Pooler, use port 6543.
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host.supabase.co:5432/postgres?prepareThreshold=0
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-supabase-password

# ===========================================
# SECURITY SECRETS
# ===========================================
# JWT Secret Key (Minimum 256 bits for HS256)
JWT_SECRET=
JWT_EXPIRATION=86400000

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# AI CONFIGURATION (Google Gemini)
# ===========================================
AI_API_KEY=your-gemini-api-key
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent
AI_MODEL=gemini-1.5-flash

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# AWS S3 Configuration (Supabase Storage compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1

# Email Configuration
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# ===========================================
# SERVER CONFIGURATION
# ===========================================
SERVER_PORT=8080
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
SPRING_JPA_HIBERNATE_DDL_AUTO=update